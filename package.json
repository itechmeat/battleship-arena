{
  "name": "battleship-arena",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "web"
  ],
  "type": "module",
  "scripts": {
    "dev:backend": "bun run --cwd ./backend dev",
    "dev:web": "bun run --cwd ./web dev",
    "build": "bun run build:backend && bun run build:web",
    "build:backend": "bun run --cwd ./backend build",
    "build:web": "bun run --cwd ./web build",
    "preview:web": "bun run --cwd ./web preview",
    "typecheck": "bun run --cwd ./shared typecheck && bun run --cwd ./backend typecheck && bun run --cwd ./web typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "DATABASE_PATH=:memory: bun test"
  },
  "devDependencies": {
    "bun-types": "1.3.13",
    "lefthook": "2.1.6",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
