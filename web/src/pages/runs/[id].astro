---
import BaseHead from "../../components/BaseHead.astro";
import ServiceWorkerScript from "../../components/ServiceWorkerScript.astro";
import LiveGame from "../../islands/LiveGame.tsx";
import { APP_FONT_STACK, DYNAMIC_ROUTE_ID } from "../../lib/page-shell.ts";

const runId = Astro.params.id ?? DYNAMIC_ROUTE_ID;
const pageTitle = runId === DYNAMIC_ROUTE_ID ? "Live run" : `Run ${runId}`;

export function getStaticPaths() {
  return [{ params: { id: DYNAMIC_ROUTE_ID } }];
}

---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${pageTitle} | BattleShipArena`} />
    <style is:global define:vars={{ appFontStack: APP_FONT_STACK }}>
      :root {
        color-scheme: light;
        font-family: var(--appFontStack);
        background:
          radial-gradient(circle at top, rgba(15, 118, 110, 0.14), transparent 38%),
          linear-gradient(180deg, #ecfeff 0%, #fffdf7 48%, #f8fafc 100%);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <LiveGame runId={runId} client:load />

    <ServiceWorkerScript />
  </body>
</html>
