---
import BaseHead from "../../../components/BaseHead.astro";
import ServiceWorkerScript from "../../../components/ServiceWorkerScript.astro";
import ReplayPlayer from "../../../islands/ReplayPlayer.tsx";
import { APP_FONT_STACK, DYNAMIC_ROUTE_ID } from "../../../lib/page-shell.ts";

const runId = Astro.params.id ?? DYNAMIC_ROUTE_ID;
const pageTitle = runId === DYNAMIC_ROUTE_ID ? "Replay" : `Replay ${runId}`;

export function getStaticPaths() {
  return [{ params: { id: DYNAMIC_ROUTE_ID } }];
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${pageTitle} | BattleShipArena`} />
    <style is:global define:vars={{ appFontStack: APP_FONT_STACK }}>
      :root {
        color-scheme: light;
        font-family: var(--appFontStack);
        background: #f8fafc;
      }

      body {
        margin: 0;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <ReplayPlayer runId={runId} client:load />

    <ServiceWorkerScript />
  </body>
</html>
