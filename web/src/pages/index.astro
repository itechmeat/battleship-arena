---
import type { HealthResponse } from "@battleship-arena/shared";

const healthStatus: HealthResponse["status"] = "ok";
const shouldRegisterServiceWorker = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f766e" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>BattleShipArena</title>
  </head>
  <body>
    <main>
      <h1>BattleShipArena</h1>
      <p data-health-status={healthStatus}>
        Mobile-first Battleship benchmark shell. Game logic and live runs land in later stories.
      </p>
    </main>

    <script is:inline define:vars={{ shouldRegisterServiceWorker }}>
      if (shouldRegisterServiceWorker) {
        window.addEventListener("load", () => {
          if ("serviceWorker" in navigator) {
            void navigator.serviceWorker.register("/sw.js");
          }
        });
      }
    </script>
  </body>
</html>
