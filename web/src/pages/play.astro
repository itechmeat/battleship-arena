---
import BaseHead from "../components/BaseHead.astro";
import ServiceWorkerScript from "../components/ServiceWorkerScript.astro";
import StartRunForm from "../islands/StartRunForm.tsx";
import { APP_FONT_STACK } from "../lib/page-shell.ts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Play | BattleShipArena" />
    <style is:global define:vars={{ appFontStack: APP_FONT_STACK }}>
      :root {
        color-scheme: light;
        font-family: var(--appFontStack);
        background:
          radial-gradient(circle at top, rgba(15, 118, 110, 0.14), transparent 38%),
          linear-gradient(180deg, #ecfeff 0%, #fffdf7 48%, #f8fafc 100%);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <StartRunForm client:load />

    <ServiceWorkerScript />
  </body>
</html>
