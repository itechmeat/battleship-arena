{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "web/.astro",
    ".agents/skills/**",
    ".claude/skills/**",
    "openspec/**"
  ]
}
