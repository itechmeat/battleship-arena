{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-7"
  },
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bash:*)",
      "Bash(openspec:*)",
      "WebSearch",
      "Bash(coderabbit:*)",
      "Skill(*)",
      "Bash(node:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(git diff)",
      "Bash(git status)",
      "Bash(git log)",
      "Bash(git show:*)",
      "Bash(git branch --list:*)",
      "Bash(git branch --show-current)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git revert:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(git branch --delete:*)",
      "Bash(git branch --move:*)",
      "Bash(git branch --rename:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["frontend-mcp"]
}
